# Stripe Secret Key (get it from https://dashboard.stripe.com/apikeys)
# Use sk_test_... for testing, sk_live_... for production
STRIPE_SECRET_KEY=sk_test_your_secret_key_here

# Stripe Webhook Secret (for webhooks - optional)
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# Price IDs from Stripe Dashboard
# Go to: https://dashboard.stripe.com/products
# Create products and copy their price IDs here
STRIPE_PRICE_STANDARD=price_xxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_PRICE_PREMIUM=price_yyyyyyyyyyyyyyyyyyyyyyyy

# Client URL (your frontend URL)
CLIENT_URL=http://localhost:3000

# Server Port
PORT=3001
